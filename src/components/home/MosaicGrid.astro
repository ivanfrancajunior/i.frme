---
import { v2 as cloudinary } from "cloudinary";

// 1. Configuração com as chaves guardadas no ficheiro .env
cloudinary.config({
  cloud_name: import.meta.env.CLOUDINARY_CLOUD_NAME,
  api_key: import.meta.env.CLOUDINARY_API_KEY,
  api_secret: import.meta.env.CLOUDINARY_API_SECRET,
  secure: true,
});

// 2. O Astro pede à API todas as imagens da pasta 'portfolio'
const { resources } = await cloudinary.search
  .sort_by("created_at",'desc')
  .max_results(80)
  .execute();

// console.log(resources);

interface Highlight {
  src: string;
  title: string;
  category: string;
}

// 3. Transformamos os dados brutos da API no formato do nosso mural
const highlights: Highlight[] = resources.map((foto: any) => ({
  // Truque: pedimos à API que redimensione a foto dinamicamente (w_800) e ajuste a qualidade (q_auto)
  src: foto.secure_url.replace("/upload/", "/upload/w_800,q_auto,f_auto/"),
  // Limpamos o nome do ficheiro para servir de título (ex: "por-do-sol-arpoador.jpg" vira "por do sol arpoador")
  title: foto.filename.replace(/-/g, " "),
  category: "2026",
}));

// Lógica de rotação e cores dos alfinetes (mantida igual)
const getRotation = (index: number): string => {
  const rotations: string[] = [
    "rotate-1",
    "-rotate-2",
    "rotate-2",
    "-rotate-1",
    "rotate-3",
    "-rotate-3",
  ];
  return rotations[index % rotations.length];
};
---

<section
  id='gallery'
  class='w-full min-h-screen bg-black pt-16 pb-24 px-4 md:px-8'
>
  <div class='max-w-7xl mx-auto mb-12'>
    <span
      class='text-xs font-sans text-gray-500 uppercase tracking-widest block mb-2'
      >Destaques</span
    >
  </div>

  <div
    class='max-w-7xl mx-auto columns-1 sm:columns-2 lg:columns-3 gap-8 space-y-8'
  >
    {
      highlights.map((photo: Highlight, index: number) => (
        <div class='break-inside-avoid'>
          <div
            class={`relative bg-white p-3 pb-6 md:p-4 md:pb-8 shadow-xl transition-transform duration-300 hover:scale-105 hover:z-50 group cursor-pointer ${getRotation(index)}`}
          >
            <a
              href={photo.src.replace("w_800", "w_1600")}
              class='glightbox block'
              data-gallery='mural-gallery'
            >
              <img
                src={photo.src}
                alt={photo.title || "Fotografia"}
                class='w-full h-auto block grayscale group-hover:grayscale-0 transition-all duration-500'
                loading='lazy'
              />
            </a>
          </div>
        </div>
      ))
    }
  </div>
</section>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
<script is:inline src="https://cdn.jsdelivr.net/gh/mcstudios/glightbox/dist/js/glightbox.min.js"></script>

<script is:inline>
  function initGallery() {
    // 1. Inicializa a galeria
    const lightbox = GLightbox({
      selector: '.glightbox',
      touchNavigation: true,
      loop: true,
      zoomable: true,
      keyboardNavigation: true
    });

    // 2. Solução Defensiva: Força a captura da tecla ESC no documento inteiro
    document.addEventListener('keydown', function(event) {
      if (event.key === 'Escape' || event.keyCode === 27) {
        // Fecha a galeria ativamente caso ela esteja aberta
        lightbox.close();
      }
    });
  }

  // 3. Cobertura total: garante que a função rode quer você use ViewTransitions do Astro ou não
  document.addEventListener('DOMContentLoaded', initGallery);
  document.addEventListener('astro:page-load', initGallery);
</script>